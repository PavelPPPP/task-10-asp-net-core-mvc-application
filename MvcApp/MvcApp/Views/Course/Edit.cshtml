@using MvcApp.Models
@model CourseModel

<h2>Edit course</h2>

<form asp-action="Edit" asp-controller="Course" asp-route-courseid="@Model.CourseId" method="post">
    <p>
        <label asp-for="Name">NAME:</label>
        <input type="text" asp-for="Name" />
    </p>
    <p>
        <label asp-for="Description">DESCRIPTION:</label>
        <input type="text" asp-for="Description" />
    </p>
    <p>
        <input type="submit" value="SAVE" />
    </p>
    <p>
        <input type="button" value="CANCEL" onclick="location.href='@Url.Action("")'" />
    </p>
</form>