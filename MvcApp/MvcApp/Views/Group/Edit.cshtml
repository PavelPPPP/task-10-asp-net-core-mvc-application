@using MvcApp.Models
@model GroupModel

<h2>Edit group</h2>

<p>
    Id course: @Model.CourseId
</p>

<form asp-action="Edit" asp-controller="Group" asp-route-groupid="@Model.GroupId" asp-route-courseid="@Model.CourseId" method="post">
    <p>
        <label asp-for="Name">NAME:</label>
        <input type="text" asp-for="Name" />
    </p>
    <p>
        <input type="submit" value="SAVE" />
    </p>
    <p>
        <input type="button" value="CANCEL" onclick="location.href='@Url.Action("GroupsOfCourse", "Group", new { id = Model.CourseId })'" />
    </p>
</form>