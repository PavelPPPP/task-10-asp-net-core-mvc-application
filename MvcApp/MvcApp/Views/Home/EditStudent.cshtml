@using MvcApp.Models
@model StudentModel

<h2>Editing student</h2>

<form asp-action="EditStudent" asp-controller="Home" asp-route-student_id="@Model.STUDENT_ID" asp-route-group_id="@Model.GROUP_ID" method="post">
    <p>
        Id student: @Model.STUDENT_ID
    </p>
    <p>
        Id group: @Model.GROUP_ID
    </p>
    <p>
        <label asp-for="FIRST_NAME">First name:</label>
        <input type="text" asp-for="FIRST_NAME" />
    </p>
    <p>
        <label asp-for="LAST_NAME">Last name:</label>
        <input type="text" asp-for="LAST_NAME" />
    </p>
    <p>
        <input type="submit" value="SAVE" />
    </p>
    <p>
        <input type="button" value="CANCEL" onclick="location.href='@Url.Action("StudentsOfGroup", "Home", new { id = Model.GROUP_ID })'" />
    </p>
</form>